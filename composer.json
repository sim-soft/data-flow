{
  "name": "simsoft/data-flow",
  "description": "A lightweight, composable ETL (Extract, Transform, Load) pipeline library for PHP with fluent API, spreadsheet support, and flow control.",
  "keywords": [
    "etl",
    "pipeline",
    "data-flow",
    "extract",
    "transform",
    "load",
    "data-processing",
    "spreadsheet",
    "csv",
    "xlsx",
    "iterator",
    "streaming",
    "batch",
    "php"
  ],
  "type": "library",
  "require": {
    "php": ">=8.3",
    "psr/log": "^3.0"
  },
  "license": "MIT",
  "suggest": {
    "simsoft/fliq": "Required for ActiveQueryExtractor — high-performance Active Record / ORM",
    "phpoffice/phpspreadsheet": "Required for SpreadsheetExtractor and SpreadsheetLoader",
    "league/flysystem": "Required for FileFinderExtractor",
    "symfony/cache": "Optional caching support for SpreadsheetLoader",
    "openspout/openspout": "Required for SpoutExtractor and SpoutLoader"
  },
  "autoload": {
    "psr-4": {
      "Simsoft\\DataFlow\\": "src",
      "Simsoft\\Spreadsheet\\": "simsoft/spreadsheet/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Simsoft\\DataFlow\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "phpunit --display-deprecations --display-warnings tests",
    "qc": [
      "phpstan analyse --memory-limit=512M",
      "phpmd src text phpmd.xml"
    ]
  },
  "require-dev": {
    "simsoft/fliq": "^1.0",
    "phpoffice/phpspreadsheet": "^5.7",
    "league/flysystem": "^3",
    "symfony/cache": "^7.4",
    "openspout/openspout": "^4.0",
    "phpunit/phpunit": "^11",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^2.1"
  }
}
